{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "./out",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "moduleResolution": "Node16",
    "types": ["node", "vscode"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".vscode-test", "out"]
}
